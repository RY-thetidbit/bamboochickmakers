# Copy to .env.local for local dev / set in Vercel project settings.
# These are optional — the site reads core business info from src/lib/site.ts.

# Public site URL (used for canonicals, sitemap, OG). Defaults to the value in src/lib/site.ts.
NEXT_PUBLIC_SITE_URL=https://bamboochickmakers.com

# Optional analytics IDs (wire up in layout if used)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
